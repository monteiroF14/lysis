{
	"ts-node": { "esm": true, "require": ["tsconfig-paths/register"] },
	"compilerOptions": {
		// base options
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "ES2022",
		"verbatimModuleSyntax": true,
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",

		// strictness
		"strict": true,
		"noUncheckedIndexedAccess": true,

		// not transpiling with TS
		"moduleResolution": "Bundler",
		"module": "NodeNext",
		"noEmit": true,

		// if code doesn't run in the DOM
		"lib": ["es2022"],

		// idk
		"baseUrl": "src/",
		"typeRoots": ["./src/types", "./node_modules/@types"]
	}
}
