{
	"ts-node": {
		"esm": true,
		"experimentalSpecifierResolution": "node"
	},
	"compilerOptions": {
		"target": "ES2017",
		"baseUrl": "./",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"module": "ES2022",
		"lib": ["es5", "es6", "dom", "es2017", "esnext.bigint"],
		"rootDir": "./src/",
		"moduleResolution": "node"
	}
}
